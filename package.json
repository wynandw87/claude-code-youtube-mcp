{
  "name": "youtube-mcp-server",
  "version": "1.0.0",
  "description": "YouTube MCP server providing video transcripts, search, metadata, channel info, playlists, comments, engagement analysis, and more",
  "main": "dist/index.js",
  "bin": {
    "youtube-mcp-server": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
